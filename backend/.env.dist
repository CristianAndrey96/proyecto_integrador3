DBMONGO=YOUR_DB_NAME
DBMONGOPASS=YOUR_USER_PASSWORD
DBMONGOSERV=YOUR_CLUSTER_SERVER
DBMONGOUSER=YOUR_USER
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173

# Email (SMTP) - para recordatorios por correo
# Ejemplo con Gmail: habilita "Contraseñas de aplicación" en tu cuenta Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion
SMTP_FROM_NAME=Taskerly
